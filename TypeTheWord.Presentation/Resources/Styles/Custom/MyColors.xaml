<?xml version="1.0" encoding="UTF-8" ?>
<?xaml-comp compile="true" ?>
<ResourceDictionary 
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- Note: For Android please see also Platforms\Android\Resources\values\colors.xml -->

    <Color x:Key="BackgroundMain">#4E6799</Color>

    <Color x:Key="GameWordColor">#FFE81F</Color>

    <LinearGradientBrush
        x:Key="BackgroundMainGradient"
        StartPoint="0,1"
        EndPoint="0,0">
        
        <GradientStop Color="#0F0F0F" Offset="0"/>
        <GradientStop Color="#121212" Offset="1"/>
    </LinearGradientBrush>

    <LinearGradientBrush
        x:Key="GradientBgLight"
        StartPoint="0,0"
        EndPoint="1,0">

        <GradientStop Color="#121212" Offset="0"/>
        <GradientStop Color="#2E2E2E" Offset="1"/>
    </LinearGradientBrush>


    <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource Primary}"/>

</ResourceDictionary>